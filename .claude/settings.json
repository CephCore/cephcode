{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "FileEditTool|FileWriteTool",
        "hooks": [
          {
            "type": "command",
            "command": "cd {{cwd}} && biome check --write {{filePath}}"
          }
        ]
      }
    ],
    "PreToolUse": []
  },
  "enabledPlugins": {
    "understand-anything@understand-anything": true,
    "cli-anything@cli-anything": true
  }
}
